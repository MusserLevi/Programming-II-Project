public class points {

    private int points = 0;
    private String word;

    public points(String word) {
        this.word = word;
        calculatePoints();
    }

    private void calculatePoints() {
        int length = word.length();

        if (length == 4) {
            points += 5;
        } else if (length == 5) {
            points += 10;
        } else if (length == 6) {
            points += 15;
        }
    }

    public int getPoints() {
        return points;
    }

    public void printPoints() {
        System.out.println("You have " + points + " points currently.");
    }
}
